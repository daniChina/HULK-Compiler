class Point(x_val: Number, y_val: Number) {
 x: Number = x_val;
 y: Number = y_val;

 getX() => self.x;
 getY() => self.y;
 sum() => self.x + self.y;
}

let p = new Point(3, 4) in {
 if (p.getX() == 3) print("ok") else print("fail");
 if (p.getY() == 4) print("ok") else print("fail");
 if (p.sum() == 7) print("ok") else print("fail");
};
