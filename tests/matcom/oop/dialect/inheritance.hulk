class Animal(n: String) {
 name: String = n;
 sound() => "...";
}

class Dog(n: String) is Animal(n) {
 sound() => "Woof";
}

class Cat(n: String) is Animal(n) {
 sound() => "Meow";
}

let d = new Dog("Rex") in print(d.sound());
let c = new Cat("Whiskers") in print(c.sound());
let a: Animal = new Dog("Buddy") in print(a.sound());
