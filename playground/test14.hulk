// TEST 14 — Versión CORREGIDA de test12: shadowing + := dentro de print(let ...)
// Salida esperada: 1, 2, 1, 10 (según evaluación del bloque y última expr a:=10)

print(let a = 1, b = a + 1 in 
{
let a = 2 in 
{ print(b); 
  print(a);
};
print(a);
a := 10;
});

