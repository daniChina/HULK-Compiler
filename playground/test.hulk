// TEST — Catálogo de mensajes sintácticos amigables (punto y coma, paréntesis, asignación)
//
// Este archivo NO compila: es la referencia de todos los casos verificados.
// Ejecutar la batería completa:
//
//   bash playground/verify_test.sh
//   bash playground/verify_test_intuitive.sh   (T2.4 — mensajes crípticos restantes)
//
// Casos puntuales (un solo error por archivo temporal):
//   ./hulk playground/test17.hulk   # grupo 1
//   ./hulk playground/test18.hulk   # grupo 2
//   ./hulk playground/test19.hulk   # grupo 3
//   ./hulk playground/test11.hulk   # T2.3
//   ./hulk playground/test12.hulk   # T2.2
//   ./hulk playground/test2.hulk    # grupo 1 (mezcla sem+sint en L1/L2)
//
// =============================================================================
// GRUPO 1 — ExprStmt: expresión completa, falta ';' al final (PostfixTail + EOF)
// Mensaje: se esperaba ';' al final de la sentencia
// =============================================================================
//
// print(1)
// pi
// 1+2
// new Point(1,2)
// let x = 1 in x
// if (true) 1 else 2
// while (true) print(1)
// unless (false) 1
// repeat (2) print(1)
// with (1 as x) x
// case 1 of a: Number => 1
// 1 := 2
// print(1); print(2)          ← segunda sentencia sin ';'
// function f() => 1
// loop print(1) while (true)  ← vía match_terminal(SEMICOLON)
// function f() => loop print(1) while (true)
//
// Referencia: test2.hulk (print(a+2); print(b+3)), test17.hulk
//
// =============================================================================
// GRUPO 2 — PostfixTail + EOF pero causa real: '(' sin cerrar
// Mensaje: falta ')' para cerrar la expresion o la llamada a funcion
// =============================================================================
//
// print(1
// print(let a=1 in a
//
// Referencia: test18.hulk
// NOTA: test13.hulk (print(let...) sin cerrar) puede seguir confundiendo ';' vs ')'
//       si el conteo de paréntesis queda balanceado al llegar a EOF.
//
// =============================================================================
// GRUPO 3 — Expr + SEMICOLON con lookahead distinto de EOF
// =============================================================================
//
// PostfixTail + RBRACE → se esperaba ';' antes de '}'
//   { print(1) }
//   { print(1); print(2) }
//   let x = 1 in { print(1) }
//   type T { m() => 1 }
//   type T { x: Number = 1 }
//   case 1 of { a: Number => 1; b: Number => 2 }   ← última rama sin ';'
//   { loop print(1) while (true) }
//
// PostfixTail + IDENTIFIER (tras case) → se esperaba ';' entre ramas del case
//   case 1 of { a: Number => 1 b: Number => 2 }
//
// Referencia: test19.hulk
//
// =============================================================================
// T2.2 — ArgListTail + SEMICOLON (test12.hulk)
// Mensaje: ';' inesperado dentro de la llamada a funcion; falta ')' para cerrar los argumentos
// =============================================================================
//
// Ver playground/test12.hulk — print(let ...);) dentro de argumentos
//
// =============================================================================
// T2.3 — PostfixTail + EQUAL (test11.hulk)
// Mensaje: no se puede usar '=' con 'c' aqui; use 'let c = ... in ...' o 'c := ...'
// =============================================================================
//
// Ver playground/test11.hulk — c=2; dentro de bloque
//
// =============================================================================
// ERRORES AÚN CRIPTOGRÁFICOS / PENDIENTES (ver respuesta en chat y test3/test6/test8)
// =============================================================================
//
// Cubiertos por verify_test_intuitive.sh + test20.hulk (T2.4 DONE)
//
// Posibles mejoras futuras:
//   - test13 con estructura distinta (print sin cerrar antes de ';')
//   - mensajes para BindingTail sin 'in' en otros contextos
//   - humanizar todos los "No hay produccion LL(1) para X" restantes
//
