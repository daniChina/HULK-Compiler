// TEST 26 - Función con let interno y recursión de cola simulada
function sum_up_to(n) =>
    let acc = 0, i = n in
    while (i > 0) {
        acc := acc + i;
        i := i - 1;
    };
// Nota: retorna el último valor de while (el de i después de decrementar)
print(sum_up_to(100));
// La suma real requiere leer acc; este test verifica que compila y corre


