// TEST 44 - Atributos con tipos explícitos
type TypedPoint(x: Number, y: Number) {
    x: Number = x;
    y: Number = y;
    distanceTo(other: TypedPoint): Number =>
        sqrt((self.x - other.x) ^ 2 + (self.y - other.y) ^ 2);
}

let p1 = new TypedPoint(0, 0), p2 = new TypedPoint(3, 4) in
    print(p1.distanceTo(p2));
// Esperado: 5


