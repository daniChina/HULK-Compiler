// TEST 48 - Definición y uso de protocolo
protocol Describable {
    describe(): String;
}

type Car(brand, model, year) {
    brand = brand;
    model = model;
    year = year;
    describe(): String => self.year @ " " @ self.brand @@ self.model;
}

let car: Describable = new Car("Toyota", "Corolla", 2023) in
    print(car.describe());
// Esperado: 2023 Toyota Corolla

// TEST 49 - Protocolo extendido
protocol Hashable {
    hash(): Number;
}

protocol Equatable extends Hashable {
    equals(other: Object): Boolean;
}

type MyInt(val: Number) {
    val = val;
    hash(): Number => self.val;
    equals(other: Object): Boolean =>
        if (other is MyInt)
            (other as MyInt).val == self.val
        else false;
}

let a = new MyInt(42), b = new MyInt(42) in
    print(if (a.equals(b)) "Iguales" else "Distintos");
// Esperado: Iguales

// TEST 50 - Covarianza en protocolo: Range implementa Iterable
// (Iterable ya está definido en builtins; range(0,5) lo implementa)
let it = range(0, 3) in {
    while (it.next()) print(it.current());
}
// Esperado: 0, 1, 2


