// TEST 52 - Iterable personalizado: cuenta regresiva
type Countdown(from: Number) {
    current = from + 1;
    next(): Boolean => (self.current := self.current - 1) > 0;
    current(): Number => self.current;
}

for (n in new Countdown(5)) print(n);
// Esperado: 5, 4, 3, 2, 1

