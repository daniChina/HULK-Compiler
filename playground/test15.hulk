// TEST 35 - Definición e instanciación básica de tipo
type Point {
    x = 0;
    y = 0;
    getX() => self.x;
    getY() => self.y;
    setX(x) => self.x := x;
    setY(y) => self.y := y;
}

let pt = new Point() in {
    pt.setX(3);
    pt.setY(4);
    print("x: " @ pt.getX() @ "; y: " @ pt.getY());
}
// Esperado: x: 3; y: 4

// TEST 36 - Tipo con argumentos (constructor simulado)
type Point2(x, y) {
    x = x;
    y = y;
    getX() => self.x;
    getY() => self.y;
    toString() => "(" @ self.x @ ", " @ self.y @ ")";
}

let p = new Point2(3, 4) in print(p.toString());
// Esperado: (3, 4)

// TEST 37 - Herencia básica
type PolarPoint(x, y) inherits Point2(x, y) {
    rho() => sqrt(self.getX() ^ 2 + self.getY() ^ 2);
    theta() => log(self.getY() / self.getX(), E);
}

let pp = new PolarPoint(3, 4) in
    print("rho: " @ pp.rho());
// Esperado: rho: 5

// TEST 38 - Polimorfismo: override de método
type Person(firstname, lastname) {
    firstname = firstname;
    lastname = lastname;
    name() => self.firstname @@ self.lastname;
}

type Knight inherits Person {
    name() => "Sir" @@ base();
}

let p = new Knight("Phil", "Collins") in print(p.name());
// Esperado: Sir Phil Collins

// TEST 39 - Uso de base() en cadena de herencia
type Animal(name) {
    name = name;
    speak() => self.name @ " hace un sonido";
}

type Dog inherits Animal {
    speak() => base() @ " (ladra: Woof!)";
}

type GoldenRetriever inherits Dog {
    speak() => base() @ " [amigablemente]";
}

let g = new GoldenRetriever("Buddy") in print(g.speak());
// Esperado: Buddy hace un sonido (ladra: Woof!) [amigablemente]

// TEST 40 - Operador is (testing de tipo dinámico)
type Bird { fly() => "flap flap"; }
type Plane { fly() => "whoooosh"; }
type Superman { }

let x = new Superman() in
    print(
        if (x is Bird) "Es un pájaro!"
        elif (x is Plane) "Es un avión!"
        else "No, es Superman!"
    );
// Esperado: No, es Superman!

// TEST 41 - Downcasting con as
type Shape(color) {
    color = color;
    area() => 0;
    describe() => "Forma de color " @ self.color @ ", area=" @ self.area();
}

type Circle(color, radius) inherits Shape(color) {
    radius = radius;
    area() => PI * self.radius ^ 2;
}

type Rectangle(color, width, height) inherits Shape(color) {
    width = width;
    height = height;
    area() => self.width * self.height;
}

let s : Shape = if (rand() < 0.5) new Circle("rojo", 5) else new Rectangle("azul", 3, 4) in {
    print(s.describe());
    if (s is Circle) {
        let c = s as Circle in
            print("Radio del círculo: " @ c.radius);
    }
    elif (s is Rectangle) {
        let r = s as Rectangle in
            print("Ancho x Alto: " @ r.width @ "x" @ r.height);
    };
}
// Esperado: descripción con área correcta + detalle del tipo concreto


