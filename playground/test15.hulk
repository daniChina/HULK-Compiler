// TEST 61 - Protocolo functor explícito
protocol NumberFilter {
    invoke(x: Number): Boolean;
}

function count_when(numbers: Number*, filter: NumberFilter): Number {
    let total = 0 in {
        for (x in numbers) total := total + if (filter(x)) 1 else 0;
        total;
    }
}

type IsEven {
    invoke(x: Number): Boolean => x % 2 == 0;
}

print(count_when(range(0, 100), new IsEven()));
// Esperado: 50

// TEST 62 - Functor con función nombrada (wrapper implícito)
function is_positive(x: Number): Boolean => x > 0;

print(count_when([-3, -1, 0, 2, 5, 7], is_positive));
// Esperado: 3

// TEST 63 - Lambda expression
let numbers = range(0, 10) in
    print(count_when(numbers, (x) => x % 3 == 0));
// Esperado: 4  (0,3,6,9)

// TEST 64 - Lambda con tipo explícito
let filter: NumberFilter = (x: Number): Boolean => x > 50 in
    print(count_when(range(0, 101), filter));
// Esperado: 50

// TEST 65 - Functor con sintaxis (T) -> U
function apply_all(nums: Number*, transform: (Number) -> Number): Number[] =>
    [transform(x) | x in nums];

let doubled = apply_all(range(1, 6), (x) => x * 2) in
    for (n in doubled) print(n);
// Esperado: 2, 4, 6, 8, 10


